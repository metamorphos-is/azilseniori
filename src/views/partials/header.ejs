<!doctype html>
<html lang="ro">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> · azilseniori.ro</title>
  <meta name="description" content="Platformă vibrantă pentru găsirea căminelor de seniori din România.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="bg-glow"></div>
  <header class="topbar">
    <a class="brand" href="/">
      <span class="brand-mark">✦</span>
      azilseniori.ro
    </a>
    <nav class="nav">
      <a href="/caut">Caut un cămin</a>
      <a href="/pentru-camine">Pentru cămine</a>
      <a href="/panou">Panou</a>
      <a href="/autentificare" class="nav-muted">Autentificare</a>
      <a href="/inscrie-camin" class="button primary">Înscrie un cămin</a>
    </nav>
    <button class="menu-toggle" aria-label="Meniu" onclick="document.body.classList.toggle('menu-open')">☰</button>
  </header>
  <main class="page">
    <% if (typeof flash !== "undefined" && flash && flash.ok) { %>
      <div class="notice ok"><%= flash.ok %></div>
    <% } %>
    <% if (typeof flash !== "undefined" && flash && flash.error) { %>
      <div class="notice error"><%= flash.error %></div>
    <% } %>
