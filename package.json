{
  "name": "azilseniori",
  "version": "0.2.0",
  "private": true,
  "description": "Platformă azilseniori.ro — marketplace cămine seniori",
  "main": "server.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch src/server.js",
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "deploy:hostinger": "node scripts/hostinger-build-manual.mjs",
    "deploy:static": "node scripts/deploy-static.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "dev:next": "npm run dev -w @azilseniori/web",
    "dev:api": "npm run dev -w @azilseniori/api",
    "build:all": "npm run build -w @azilseniori/database && npm run build -w @azilseniori/api && npm run build -w @azilseniori/web",
    "lint": "npm run lint -w @azilseniori/web && npm run lint -w @azilseniori/api",
    "typecheck": "npm run typecheck -w @azilseniori/web && npm run typecheck -w @azilseniori/api && npm run typecheck -w @azilseniori/database"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "prisma": "^6.19.0",
    "tsx": "^4.20.6"
  },
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma",
    "seed": "tsx packages/database/prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
